{
  "streams": {
    "nodes_csv": {
      "name": "nodes_csv",
      "output_format": "csv",
      "output_path": "backend/data/streams/nodes_stream.csv",
      "update_interval_seconds": 30,
      "rotation_interval_minutes": 60,
      "variation_factor": 0.3,
      "enable_failures": true,
      "failure_probability": 0.02,
      "max_file_size_mb": 10,
      "keep_history_files": 24
    },
    "nodes_jsonl": {
      "name": "nodes_jsonl",
      "output_format": "jsonl",
      "output_path": "backend/data/streams/nodes_stream.jsonl",
      "update_interval_seconds": 15,
      "rotation_interval_minutes": 30,
      "variation_factor": 0.2,
      "enable_failures": true,
      "failure_probability": 0.02,
      "max_file_size_mb": 5,
      "keep_history_files": 48
    },
    "supply_events": {
      "name": "supply_events",
      "output_format": "jsonl",
      "output_path": "backend/data/streams/supply_events.jsonl",
      "update_interval_seconds": 60,
      "rotation_interval_minutes": 120,
      "variation_factor": 0.4,
      "enable_failures": true,
      "failure_probability": 0.03,
      "max_file_size_mb": 5,
      "keep_history_files": 12
    },
    "failure_scenarios": {
      "name": "failure_scenarios",
      "output_format": "jsonl",
      "output_path": "backend/data/streams/failure_scenarios.jsonl",
      "update_interval_seconds": 300,
      "rotation_interval_minutes": 240,
      "variation_factor": 0.5,
      "enable_failures": true,
      "failure_probability": 0.05,
      "max_file_size_mb": 8,
      "keep_history_files": 6
    }
  },
  "failure_scenarios": {
    "grid_outage": {
      "name": "grid_outage",
      "description": "Complete grid power failure",
      "trigger_probability": 0.02,
      "duration_minutes": [15, 120],
      "supply_reduction_percent": [80, 100],
      "affected_sources": ["grid"],
      "recovery_pattern": "gradual"
    },
    "solar_cloud_cover": {
      "name": "solar_cloud_cover",
      "description": "Heavy cloud cover reducing solar output",
      "trigger_probability": 0.05,
      "duration_minutes": [30, 180],
      "supply_reduction_percent": [40, 80],
      "affected_sources": ["solar"],
      "recovery_pattern": "gradual"
    },
    "battery_degradation": {
      "name": "battery_degradation",
      "description": "Battery system performance degradation",
      "trigger_probability": 0.01,
      "duration_minutes": [60, 480],
      "supply_reduction_percent": [30, 60],
      "affected_sources": ["battery"],
      "recovery_pattern": "stepped"
    },
    "diesel_shortage": {
      "name": "diesel_shortage",
      "description": "Diesel generator fuel shortage",
      "trigger_probability": 0.008,
      "duration_minutes": [120, 600],
      "supply_reduction_percent": [70, 100],
      "affected_sources": ["diesel"],
      "recovery_pattern": "immediate"
    },
    "cascade_failure": {
      "name": "cascade_failure",
      "description": "Cascading failure affecting multiple sources",
      "trigger_probability": 0.005,
      "duration_minutes": [45, 240],
      "supply_reduction_percent": [50, 90],
      "affected_sources": ["grid", "solar", "battery"],
      "recovery_pattern": "stepped"
    }
  }
}